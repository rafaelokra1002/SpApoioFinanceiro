generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id              String     @id @default(uuid())
  nome            String
  telefone        String
  cpf             String?
  email           String?
  instagram       String?
  renda           String?
  valorSolicitado Float
  valorTotal      Float
  taxaJuros       Float      @default(30)
  prazo           Int        @default(30)
  cidade          String
  perfil          String
  nomeEmpresa     String?
  bairroTrabalho  String?
  status          String     @default("PENDENTE")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  documentos      Document[]
}

model Document {
  id        String   @id @default(uuid())
  leadId    String
  tipo      String
  url       String
  filename  String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Simulation {
  id              String   @id @default(uuid())
  valorSolicitado Float
  valorTotal      Float
  taxaJuros       Float    @default(30)
  prazo           Int      @default(30)
  cidade          String
  createdAt       DateTime @default(now())
}

model Category {
  id        String             @id @default(uuid())
  value     String             @unique
  label     String
  icon      String             @default("📋")
  order     Int                @default(0)
  active    Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  documents CategoryDocument[]
}

model CategoryDocument {
  id          String   @id @default(uuid())
  categoryId  String
  key         String
  label       String
  description String   @default("")
  icon        String   @default("📄")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}